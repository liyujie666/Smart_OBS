  <property name="windowTitle">
   <string>Form</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QWidget{
	border-radius:3px;
	background-color:rgb(39, 42, 51);
	min-height:30px;
	max-height:30px;
}

QLabel{
	color:white;
}

QSlider::groove:horizontal {
    border: none;
    height: 6px;
    background: #3c3f41;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background: white;         /* 滑块颜色（可自定义为 OBS 高亮色） */
    border: none;
    width: 22px;
    height: 12px;
    margin: -4px 0;              /* 垂直居中 handle */
    border-radius: 6px;
}

QSlider::sub-page:horizontal {
    background: #476BD7;         /* 进度填充颜色 */
    border-radius: 3px;
}

QSlider::add-page:horizontal {
    background: #464B59;         /* 未填充部分 */
    border-radius: 3px;
}

QPushButton{
	min-width:35px;
	min-height:28px;
	max-width:35px;
	max-height:28px;
	background-color:#464B59
}</string>
  </property>
