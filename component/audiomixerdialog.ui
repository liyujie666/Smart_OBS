        <property name="styleSheet">
         <string notr="true">/* 去除表格所有边框样式 */
QTableWidget {
    border: none;               /* 去除表格最外层边框 */
    background-color: #272A33;  /* 背景色（可根据需要调整） */
    color: #ffffff;             /* 文字颜色 */
    gridline-color: transparent;/* 网格线透明 */
}

QTableWidget::item {
    border: none;               /* 去除单元格边框 */
    padding: 4px 8px;           /* 单元格内边距 */
	text-align: left; /* 水平靠左 */
    vertical-align: middle; /* 垂直居中 */
}

/* 表头样式 */
QHeaderView::section {
    border: none;               /* 去除表头边框 */
    background-color: #272A33;  /* 表头背景色 */
    color: #ffffff;             /* 表头文字颜色 */
    padding: 6px 8px;           /* 表头内边距 */
	text-align:left;
    vertical-align: middle; /* 垂直居中 */
}

/* 滚动区域边框去除 */
QTableWidget QScrollArea {
    border: none;
}

/* 滚动条样式（可选） */
QTableWidget QScrollBar:vertical {
    background-color: #272822;
    width: 8px;
    margin: 0px;
}

QTableWidget QScrollBar::handle:vertical {
    background-color: #555555;
    border-radius: 4px;
}

QTableWidget QScrollBar:horizontal {
    background-color: #272822;
    height: 8px;
    margin: 0px;
}

QTableWidget QScrollBar::handle:horizontal {
    background-color: #555555;
    border-radius: 4px;
}

