  <property name="styleSheet">
   <string notr="true">QDialog{
	background-color:#1D1F26
}


QLabel{
	color:white;
	font-size:14px;
	min-width:100px;
	max-width:100px;
}

QLineEdit{
	 background-color: #3C404D;
    border: 1px solid #3C3C3C;
    border-radius: 5px;
    padding: 4px 8px;
    color: white;
    font-size: 13px;
	min-height:25px;
	max-height:25px;

}
QComboBox {
    background-color: #3C404D;
    border: 1px solid #3C3C3C;
    border-radius: 5px;
    padding: 4px 8px;
    color: white;
    font-size: 13px;
	min-height:25px;
	max-height:25px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left: 1px solid #3C3C3C;
    background-color: #3C404D;
}

QComboBox::down-arrow {
    image: url(:/sources/down.png);  /* 你可以用自己的箭头图标 */
	background-color: #3C404D;
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    background-color: #3C404D;
    border: 1px solid #3C3C3C;
    selection-background-color: #284CB8;
    selection-color: white;
    color: white;
    font-size: 13px;
    outline: 0;
}

QPushButton {
        background-color: #3C404D;
        border: none;
         border-radius: 4px;
         padding: 6px 12px;
         color: white;
		min-width:50px;
		max-width:50px;
		min-height:25px;
		max-height:25px;

}
QPushButton:hover { background-color: #3c3d47; }
QPushButton:pressed { background-color: #50515b; }


QSpinBox {
    background-color: #3C404D;
    border: 1px solid #3C3C3C;
    border-radius: 5px;
    padding: 4px 8px;
    color: white;
    font-size: 13px;
    min-height: 25px;
    max-height: 25px;
}

/* 去除边框阴影等默认效果 */
QSpinBox:focus {
    border: 1px solid #284CB8;
}

/* 上下按钮区域 */
QSpinBox::up-button, QSpinBox::down-button {
    background-color: #3C404D;
    subcontrol-origin: border;
    width: 20px;
    border-left: 1px solid #3C3C3C;
}

/* 上按钮图标 */
QSpinBox::up-arrow {
    image: url(:/sources/up.png); /* 使用你自己的图标 */
    width: 12px;
    height: 12px;
}

/* 下按钮图标 */
QSpinBox::down-arrow {
    image: url(:/sources/down.png); /* 使用你自己的图标 */
    width: 12px;
    height: 12px;
}

/* 关闭上下按钮按下时的高亮 */
QSpinBox::up-button:pressed,
QSpinBox::down-button:pressed {
    background-color: #50555E;
}

/* 去除输入焦点边框 */
QSpinBox::edit-field {
    background: transparent;
    padding-right: 24px; /* 给按钮留空间 */
}




QDoubleSpinBox {
    background-color: #3C404D;
    border: 1px solid #3C3C3C;
    border-radius: 5px;
    padding: 4px 8px;
    color: white;
    font-size: 13px;
    min-height: 25px;
    max-height: 25px;
}

/* 去除边框阴影等默认效果 */
QDoubleSpinBox:focus {
    border: 1px solid #284CB8;
}

/* 上下按钮区域 */
QDoubleSpinBox::up-button, QDoubleSpinBox::down-button {
    background-color: #3C404D;
    subcontrol-origin: border;
    width: 20px;
    border-left: 1px solid #3C3C3C;
}

/* 上按钮图标 */
QDoubleSpinBox::up-arrow {
    image: url(:/sources/up.png); /* 使用你自己的图标 */
    width: 12px;
    height: 12px;
}

/* 下按钮图标 */
QDoubleSpinBox::down-arrow {
    image: url(:/sources/down.png); /* 使用你自己的图标 */
    width: 12px;
    height: 12px;
}

/* 关闭上下按钮按下时的高亮 */
QDoubleSpinBox::up-button:pressed,
QDoubleSpinBox::down-button:pressed {
    background-color: #50555E;
}

/* 去除输入焦点边框 */
QDoubleSpinBox::edit-field {
    background: transparent;
    padding-right: 24px; /* 给按钮留空间 */
}</string>
