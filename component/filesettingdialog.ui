<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>FileSettingDialog</class>
 <widget class="QDialog" name="FileSettingDialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>675</width>
    <height>163</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Dialog</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QDialog{
	background-color:#1D1F26
}
QLabel{
	color:white;
	font-size:14px;
	min-width:100px;
	max-width:100px;
}

QLineEdit{
	 background-color: #3C404D;
    border: 1px solid #3C3C3C;
    border-radius: 5px;
    padding: 4px 8px;
    color: white;
    font-size: 13px;
	min-height:25px;
	max-height:25px;

}
QComboBox {
    background-color: #3C404D;
    border: 1px solid #3C3C3C;
    border-radius: 5px;
    padding: 4px 8px;
    color: white;
    font-size: 13px;
	min-height:25px;
	max-height:25px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left: 1px solid #3C3C3C;
    background-color: #3C404D;
}

QComboBox::down-arrow {
    image: url(:/sources/down.png);  /* 你可以用自己的箭头图标 */
	background-color: #3C404D;
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    background-color: #3C404D;
    border: 1px solid #3C3C3C;
    selection-background-color: #284CB8;
    selection-color: white;
    color: white;
    font-size: 13px;
    outline: 0;
}

QPushButton {
        background-color: #3C404D;
        border: none;
         border-radius: 4px;
         padding: 6px 12px;
         color: white;
		min-width:50px;
		max-width:50px;
		min-height:25px;
		max-height:25px;

}
QPushButton:hover { background-color: #3c3d47; }
QPushButton:pressed { background-color: #50515b; }
QSlider::groove:horizontal {
    border: none;
    height: 6px;
    background: #3c3f41;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background: white;         /* 滑块颜色（可自定义为 OBS 高亮色） */
    border: none;
    width: 20px;
    height: 12px;
    margin: -4px 0;              /* 垂直居中 handle */
    border-radius: 6px;
}

QSlider::sub-page:horizontal {
    background: #476BD7;         /* 进度填充颜色 */
    border-radius: 3px;
}

QSlider::add-page:horizontal {
    background: #464B59;         /* 未填充部分 */
    border-radius: 3px;
}

</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <layout class="QHBoxLayout" name="horizontalLayout">
     <item>
      <widget class="QLabel" name="label">
       <property name="text">
